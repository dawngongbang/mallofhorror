{
  "rules": {
    "games": {
      "$roomId": {
        "meta": {
          ".read": true,
          ".write": "auth != null && (!data.exists() || auth.uid === data.child('hostId').val())"
        },

        "players": {
          ".read": true,
          "$playerId": {
            ".write": "auth.uid === $playerId"
          }
        },

        "game": {
          ".write": "auth.uid === root.child('games').child($roomId).child('meta/hostId').val()",

          "phase":                  { ".read": true },
          "round":                  { ".read": true },
          "phaseDeadline":          { ".read": true },
          "phaseStartedAt":         { ".read": true },
          "playerOrder":            { ".read": true },
          "sheriffIndex":           { ".read": true },
          "isRealSheriff":          { ".read": true },
          "nextSheriffPlayerId":    { ".read": true },
          "characters":             { ".read": true },
          "zones":                  { ".read": true },
          "setupPlacementOrder":    { ".read": true },
          "setupDiceRoll":          { ".read": true },
          "characterDeclarations":  { ".read": true },
          "declarationOrder":       { ".read": true },
          "destinationStatus":      { ".read": true },
          "resolvedMoves":          { ".read": true },
          "currentEventZoneIndex":  { ".read": true },
          "currentVote":            { ".read": true },
          "itemSearchPreview":      { ".read": true },
          "cardReactionWindow":     { ".read": true },
          "winners":                { ".read": true },
          "finalScores":            { ".read": true },

          "lastDiceRoll": {
            ".read": "auth.uid === root.child('games').child($roomId).child('meta/hostId').val()"
          },

          "characterDeclarations": {
            "$playerId": {
              ".read": true,
              ".write": "auth.uid === $playerId"
            }
          },

          "sealedDestinations": {
            "$playerId": {
              ".read": "auth.uid === $playerId || auth.uid === root.child('games').child($roomId).child('meta/hostId').val()",
              ".write": "auth.uid === $playerId"
            }
          },

          "currentVote": {
            "votes": {
              "$playerId": { ".write": "auth.uid === $playerId" }
            },
            "status": {
              "$playerId": { ".write": "auth.uid === $playerId" }
            }
          },

          "pendingItemActions": {
            "$playerId": {
              ".read": "auth.uid === $playerId || auth.uid === root.child('games').child($roomId).child('meta/hostId').val()",
              ".write": "auth.uid === $playerId"
            }
          },

          "$other": {
            ".write": "auth.uid === root.child('games').child($roomId).child('meta/hostId').val() || root.child('games').child($roomId).child('game/phase').val() === 'setup_place'"
          }
        },

        "private": {
          "$playerId": {
            ".read": "auth.uid === $playerId || auth.uid === root.child('games').child($roomId).child('meta/hostId').val()",
            ".write": "auth.uid === $playerId || auth.uid === root.child('games').child($roomId).child('meta/hostId').val()"
          }
        },

        "chat": {
          ".read": true,
          "$messageId": {
            ".write": "auth != null && !data.exists()"
          }
        }
      }
    }
  }
}
